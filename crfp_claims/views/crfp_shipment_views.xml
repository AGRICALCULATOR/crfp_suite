<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Claims smart button and Report Claim to Shipment form -->
    <record id="crfp_shipment_form_inherit_claims" model="ir.ui.view">
        <field name="name">crfp.shipment.form.claims</field>
        <field name="model">crfp.shipment</field>
        <field name="inherit_id" ref="crfp_logistics.crfp_shipment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_claims" type="object"
                        class="oe_stat_button" icon="fa-exclamation-triangle"
                        invisible="claim_count == 0">
                    <field name="claim_count" widget="statinfo" string="Claims"/>
                </button>
                <button name="action_report_claim" type="object"
                        class="oe_stat_button" icon="fa-flag"
                        string="Report Claim"/>
            </xpath>
        </field>
    </record>
</odoo>
