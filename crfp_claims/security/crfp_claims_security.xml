<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_crfp_claims_user" model="res.groups">
        <field name="name">CR Farm Claims - User</field>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_crfp_claims_manager" model="res.groups">
        <field name="name">CR Farm Claims - Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_crfp_claims_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
