<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="crfp_multicurrency_reports.CurrencyFilter"
       t-inherit="account_reports.AccountReportFilters"
       t-inherit-mode="extension">
        <xpath expr="//div[@id='filter_rounding_unit']" position="after">
            <t t-if="'currency_filter' in controller.cachedFilterOptions">
                <div id="filter_currency" class="btn-group">
                    <Dropdown togglerClass="'btn btn-secondary'">
                        <t t-set-slot="toggler">
                            <i class="fa fa-money me-1"/>
                            <t t-esc="this.getSelectedCurrencyName()"/>
                        </t>
                        <t t-foreach="controller.cachedFilterOptions.currency_filter.available_currencies"
                           t-as="currency" t-key="currency.id">
                            <DropdownItem onSelected="() => this.onCurrencySelected(currency.id)">
                                <span t-att-class="currency.selected ? 'fw-bold' : ''">
                                    <t t-esc="currency.name"/>
                                    <span class="text-muted ms-1">(<t t-esc="currency.symbol"/>)</span>
                                </span>
                            </DropdownItem>
                        </t>
                    </Dropdown>
                </div>
            </t>
        </xpath>
    </t>
</templates>
