<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crfp_document_tree" model="ir.ui.view">
        <field name="name">crfp.shipment.document.list</field>
        <field name="model">crfp.shipment.document</field>
        <field name="arch" type="xml">
            <list decoration-danger="is_overdue" decoration-muted="state in ('na','approved')">
                <field name="shipment_id"/>
                <field name="doc_type"/>
                <field name="doc_source" widget="badge"/>
                <field name="reference"/>
                <field name="date_required"/>
                <field name="responsible_id"/>
                <field name="is_overdue" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('approved','received')"
                       decoration-warning="state in ('in_progress','ready','sent')"
                       decoration-danger="state == 'rejected'"
                       decoration-muted="state == 'na'"/>
            </list>
        </field>
    </record>

    <record id="action_crfp_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">crfp.shipment.document</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
