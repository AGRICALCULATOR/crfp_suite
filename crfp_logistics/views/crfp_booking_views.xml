<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crfp_booking_tree" model="ir.ui.view">
        <field name="name">crfp.shipment.booking.list</field>
        <field name="model">crfp.shipment.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="booking_reference"/>
                <field name="shipment_id"/>
                <field name="carrier_partner_id"/>
                <field name="vessel_name"/>
                <field name="etd"/>
                <field name="containers_qty"/>
                <field name="freight_cost"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-warning="state == 'requested'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="crfp_booking_form" model="ir.ui.view">
        <field name="name">crfp.shipment.booking.form</field>
        <field name="model">crfp.shipment.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm Booking"
                            class="btn-primary" invisible="state != 'requested'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('cancelled',)"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Booking Info">
                            <field name="booking_reference"/>
                            <field name="shipment_id"/>
                            <field name="carrier_partner_id" options="{'no_create': True}"/>
                            <field name="contact_person"/>
                            <field name="request_date"/>
                            <field name="confirmation_date"/>
                        </group>
                        <group string="Transport Details">
                            <field name="vessel_name"/>
                            <field name="voyage_number"/>
                            <field name="container_type_id"/>
                            <field name="containers_qty"/>
                            <field name="cutoff_date"/>
                            <field name="etd"/>
                            <field name="eta"/>
                            <field name="freight_cost"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Booking notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_crfp_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">crfp.shipment.booking</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
