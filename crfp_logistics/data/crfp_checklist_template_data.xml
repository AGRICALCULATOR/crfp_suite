<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default FOB checklist template -->
        <record id="checklist_template_fob" model="crfp.checklist.template">
            <field name="name">FOB Export — Standard Checklist</field>
            <field name="incoterm_filter">FOB</field>
        </record>
        <record id="ct_fob_01" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Confirm booking with carrier</field>
            <field name="sequence">10</field><field name="category">logistics</field><field name="is_blocking" eval="True"/>
        </record>
        <record id="ct_fob_02" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Send shipping instructions to carrier/forwarder</field>
            <field name="sequence">20</field><field name="category">logistics</field><field name="is_blocking" eval="True"/>
        </record>
        <record id="ct_fob_03" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Confirm actual packed quantities</field>
            <field name="sequence">30</field><field name="category">logistics</field><field name="is_blocking" eval="True"/>
        </record>
        <record id="ct_fob_04" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Obtain phytosanitary certificate</field>
            <field name="sequence">40</field><field name="category">documentation</field><field name="is_blocking" eval="True"/>
        </record>
        <record id="ct_fob_05" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Obtain certificate of origin</field>
            <field name="sequence">50</field><field name="category">documentation</field>
        </record>
        <record id="ct_fob_06" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Review BL draft</field>
            <field name="sequence">60</field><field name="category">documentation</field><field name="is_blocking" eval="True"/>
        </record>
        <record id="ct_fob_07" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Generate packing list from actual quantities</field>
            <field name="sequence">70</field><field name="category">documentation</field><field name="is_blocking" eval="True"/>
        </record>
        <record id="ct_fob_08" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Verify container gate-in at terminal</field>
            <field name="sequence">80</field><field name="category">logistics</field>
        </record>
        <record id="ct_fob_09" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Confirm vessel departure (ATD)</field>
            <field name="sequence">90</field><field name="category">logistics</field>
        </record>
        <record id="ct_fob_10" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Send document package to client</field>
            <field name="sequence">100</field><field name="category">documentation</field>
        </record>
        <record id="ct_fob_11" model="crfp.checklist.template.line">
            <field name="template_id" ref="checklist_template_fob"/>
            <field name="name">Register commercial invoice in Odoo</field>
            <field name="sequence">110</field><field name="category">commercial</field>
        </record>
    </data>
</odoo>
