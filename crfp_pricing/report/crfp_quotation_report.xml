<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report action -->
    <record id="action_report_crfp_quotation" model="ir.actions.report">
        <field name="name">Export Price Quotation</field>
        <field name="model">crfp.quotation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">crfp_pricing.report_crfp_quotation</field>
        <field name="report_file">crfp_pricing.report_crfp_quotation</field>
        <field name="binding_model_id" ref="model_crfp_quotation"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb template -->
    <template id="report_crfp_quotation">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Segoe UI', Arial, sans-serif; color: #2d2d2d;">

                        <!-- Header bar -->
                        <div style="background: linear-gradient(135deg, #1a4d2e 0%, #2d7a4a 100%); color: white; padding: 20px 28px; border-radius: 8px; margin-bottom: 20px;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <h2 style="margin: 0; font-size: 24px; font-weight: 700; letter-spacing: 0.5px;">
                                        EXPORT PRICE QUOTATION
                                    </h2>
                                    <p style="margin: 4px 0 0; font-size: 13px; opacity: 0.85; font-weight: 500;">
                                        CR FARM PRODUCTS VYM S.A
                                    </p>
                                </div>
                                <div style="text-align: right;">
                                    <p style="margin: 0; font-size: 12px; opacity: 0.8;">
                                        Date: <strong t-esc="o.create_date.strftime('%Y-%m-%d') if o.create_date else ''"/>
                                    </p>
                                    <p style="margin: 4px 0 0; font-size: 14px; font-weight: 700;">
                                        <t t-esc="o.name"/>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Client and terms cards -->
                        <div style="display: flex; gap: 20px; margin-bottom: 22px;">
                            <!-- Client card -->
                            <div style="flex: 1; background: #f8faf9; border: 1px solid #e2e8e4; border-radius: 6px; padding: 14px 18px;">
                                <p style="font-size: 9px; color: #888; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 6px;">Client</p>
                                <p style="font-size: 16px; font-weight: 700; margin: 0; color: #1a4d2e;" t-esc="o.partner_id.name or '—'"/>
                                <p style="font-size: 11px; color: #666; margin: 4px 0 0;" t-if="o.partner_id.email" t-esc="o.partner_id.email"/>
                            </div>
                            <!-- Details card -->
                            <div style="flex: 1; background: #f8faf9; border: 1px solid #e2e8e4; border-radius: 6px; padding: 14px 18px;">
                                <table style="font-size: 11px; width: 100%; border-collapse: collapse;">
                                    <tr>
                                        <td style="color: #888; padding: 3px 10px 3px 0; width: 40%;">Incoterm</td>
                                        <td style="font-weight: 700; color: #1a4d2e;" t-esc="o.incoterm"/>
                                    </tr>
                                    <tr>
                                        <td style="color: #888; padding: 3px 10px 3px 0;">Destination</td>
                                        <td style="font-weight: 700;" t-esc="o.port_id.name or '—'"/>
                                    </tr>
                                    <tr>
                                        <td style="color: #888; padding: 3px 10px 3px 0;">Exchange Rate</td>
                                        <td style="font-weight: 700;">₡<t t-esc="'%.2f' % o.exchange_rate"/> / USD</td>
                                    </tr>
                                    <tr t-if="o.vessel_name">
                                        <td style="color: #888; padding: 3px 10px 3px 0;">Vessel</td>
                                        <td t-esc="o.vessel_name"/>
                                    </tr>
                                    <tr t-if="o.etd">
                                        <td style="color: #888; padding: 3px 10px 3px 0;">ETD</td>
                                        <td t-esc="o.etd"/>
                                    </tr>
                                    <tr t-if="o.eta">
                                        <td style="color: #888; padding: 3px 10px 3px 0;">ETA</td>
                                        <td t-esc="o.eta"/>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Products table -->
                        <table style="width: 100%; border-collapse: collapse; font-size: 11px; margin-bottom: 20px;">
                            <thead>
                                <tr style="background: #1a4d2e; color: white;">
                                    <th style="padding: 10px 12px; text-align: left; border-radius: 6px 0 0 0;">Product</th>
                                    <th style="padding: 10px 8px; text-align: center;">Net Kg</th>
                                    <th style="padding: 10px 8px; text-align: right;">EXW Price</th>
                                    <th style="padding: 10px 8px; text-align: right;">Logistics</th>
                                    <th style="padding: 10px 8px; text-align: right;">Price/Box</th>
                                    <th style="padding: 10px 8px; text-align: center; border-radius: 0 6px 0 0;">Boxes/Plt</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.line_ids" t-as="line">
                                  <t t-if="line.include_in_pdf">
                                    <tr t-attf-style="border-bottom: 1px solid #e8ece9; #{line_index % 2 and 'background: #f8faf9;' or ''}">
                                        <td style="padding: 8px 12px; font-weight: 600;" t-esc="line.crfp_product_id.name"/>
                                        <td style="padding: 8px; text-align: center; font-family: 'Courier New', monospace;" t-esc="'%.1f' % line.net_kg"/>
                                        <td style="padding: 8px; text-align: right; font-family: 'Courier New', monospace; color: #555;" t-esc="'$%.2f' % line.exw_price"/>
                                        <td style="padding: 8px; text-align: right; font-family: 'Courier New', monospace; color: #3d8b5c;" t-esc="'$%.4f' % line.logistics_per_box"/>
                                        <td style="padding: 8px; text-align: right; font-family: 'Courier New', monospace; font-weight: 700; font-size: 12px; color: #1a4d2e;" t-esc="'$%.2f' % line.final_price"/>
                                        <td style="padding: 8px; text-align: center; font-family: 'Courier New', monospace;" t-esc="line.boxes_per_pallet"/>
                                    </tr>
                                  </t>
                                </t>
                            </tbody>
                        </table>

                        <!-- Footer terms -->
                        <div style="background: #f0f7f2; border-left: 4px solid #1a4d2e; border-radius: 0 6px 6px 0; padding: 12px 18px; font-size: 11px; color: #1a4d2e;">
                            <p style="margin: 0; line-height: 1.6;">
                                <strong>Terms:</strong> Prices in USD, <t t-esc="o.incoterm"/> — <t t-esc="o.port_id.name or ''"/>.
                                Valid for 7 days from quotation date. Subject to product availability.
                            </p>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
