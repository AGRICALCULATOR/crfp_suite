<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report action -->
    <record id="action_report_crfp_quotation" model="ir.actions.report">
        <field name="name">Export Price Quotation</field>
        <field name="model">crfp.quotation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">crfp_pricing.report_crfp_quotation</field>
        <field name="report_file">crfp_pricing.report_crfp_quotation</field>
        <field name="binding_model_id" ref="model_crfp_quotation"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb template — matches Odoo 19 standard document style -->
    <template id="report_crfp_quotation">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- Title row -->
                        <div class="row mt-4 mb-4">
                            <div class="col-7">
                                <t t-if="o.partner_id">
                                    <div t-field="o.partner_id"
                                         t-options='{"widget": "contact", "fields": ["name", "address", "vat"], "no_marker": true}'/>
                                </t>
                            </div>
                            <div class="col-5 text-right">
                                <h2 style="color: #1a6b3c; font-weight: 700;">
                                    Price List — <span t-esc="o.name"/>
                                </h2>
                            </div>
                        </div>

                        <!-- Details row -->
                        <div class="row mb-4" style="font-size: 12px;">
                            <div class="col-3">
                                <strong style="color: #1a6b3c;">Date</strong><br/>
                                <span t-esc="o.create_date.strftime('%m/%d/%Y') if o.create_date else ''"/>
                            </div>
                            <div class="col-3">
                                <strong style="color: #1a6b3c;">Incoterm</strong><br/>
                                <span t-esc="o.incoterm or '—'"/>
                                <t t-if="o.port_id">
                                    <br/><span style="color: #666;" t-esc="o.port_id.name"/>
                                </t>
                            </div>
                            <div class="col-3" t-if="o.etd">
                                <strong style="color: #1a6b3c;">ETD</strong><br/>
                                <span t-esc="o.etd"/>
                            </div>
                            <div class="col-3" t-if="o.eta">
                                <strong style="color: #1a6b3c;">ETA</strong><br/>
                                <span t-esc="o.eta"/>
                            </div>
                        </div>

                        <!-- Products table -->
                        <table class="table table-sm" style="font-size: 13px;">
                            <thead>
                                <tr style="background: #1a6b3c; color: white;">
                                    <th style="padding: 8px 10px; font-weight: 500; text-transform: uppercase; font-size: 9px; letter-spacing: 0.5px; border: none;">
                                        Product
                                    </th>
                                    <th style="padding: 8px 6px; text-align: center; font-weight: 500; text-transform: uppercase; font-size: 9px; letter-spacing: 0.5px; border: none;">
                                        Net Kg
                                    </th>
                                    <th style="padding: 8px 6px; text-align: right; font-weight: 400; text-transform: uppercase; font-size: 9px; letter-spacing: 0.5px; border: none; opacity: 0.75;">
                                        EXW
                                    </th>
                                    <th style="padding: 8px 6px; text-align: right; font-weight: 400; text-transform: uppercase; font-size: 9px; letter-spacing: 0.5px; border: none; opacity: 0.75;">
                                        Logistics
                                    </th>
                                    <th style="padding: 8px 10px; text-align: right; font-weight: 700; font-size: 10px; border: none;">
                                        Price / Box
                                    </th>
                                    <th style="padding: 8px 6px; text-align: center; font-weight: 500; text-transform: uppercase; font-size: 9px; letter-spacing: 0.5px; border: none;">
                                        Box/Plt
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="row_idx" t-value="0"/>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <t t-if="line.include_in_pdf">
                                        <t t-set="row_idx" t-value="row_idx + 1"/>
                                        <tr t-attf-style="background: #{row_idx % 2 == 0 and '#f5f8f6' or 'white'};">
                                            <td style="padding: 7px 10px; border-color: #e8eee9; font-weight: 600;">
                                                <t t-esc="line.crfp_product_id.name"/>
                                            </td>
                                            <td style="padding: 7px 6px; text-align: center; border-color: #e8eee9; color: #555;">
                                                <t t-esc="'%.1f' % line.net_kg"/>
                                            </td>
                                            <td style="padding: 7px 6px; text-align: right; border-color: #e8eee9; color: #999; font-size: 12px;">
                                                $<t t-esc="'%.2f' % line.exw_price"/>
                                            </td>
                                            <td style="padding: 7px 6px; text-align: right; border-color: #e8eee9; color: #999; font-size: 12px;">
                                                $<t t-esc="'%.2f' % line.logistics_per_box"/>
                                            </td>
                                            <td style="padding: 7px 10px; text-align: right; border-color: #e8eee9; font-weight: 700; font-size: 15px; color: #1a6b3c;">
                                                $<t t-esc="'%.2f' % line.final_price"/>
                                            </td>
                                            <td style="padding: 7px 6px; text-align: center; border-color: #e8eee9; color: #555;">
                                                <t t-esc="line.boxes_per_pallet"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>

                        <!-- Footer note -->
                        <div class="row mt-3">
                            <div class="col-12">
                                <p style="font-size: 9px; color: #aaa; margin: 0;">
                                    Prices in USD ·
                                    <strong style="color: #777;"><t t-esc="o.incoterm"/></strong>
                                    <t t-if="o.port_id"> <t t-esc="o.port_id.name"/></t>
                                    · Valid 7 days · Subject to availability
                                </p>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
