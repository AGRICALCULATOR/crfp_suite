<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="email_template_crfp_quotation" model="mail.template">
            <field name="name">CRFP: Export Price Quotation</field>
            <field name="model_id" ref="crfp_pricing.model_crfp_quotation"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="subject">Export Price Quotation — {{ object.name }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px;">
    <p>Dear {{ object.partner_id.name or 'Customer' }},</p>
    <p>Please find attached our export price quotation <strong>{{ object.name }}</strong>.</p>
    <table style="font-size: 13px; margin: 12px 0;">
        <tr><td style="padding: 3px 12px 3px 0; color: #888;">Incoterm:</td><td style="font-weight: 700;">{{ object.incoterm }}</td></tr>
        <tr><td style="padding: 3px 12px 3px 0; color: #888;">Destination:</td><td style="font-weight: 700;">{{ object.port_id.name or '—' }}</td></tr>
        <tr><td style="padding: 3px 12px 3px 0; color: #888;">Products:</td><td>{{ object.line_count }} items</td></tr>
    </table>
    <p>Prices are valid for 7 days. Please let us know if you have any questions or would like to confirm an order.</p>
    <p>Best regards,<br/>
    <strong>CR Farm Products VYM S.A</strong></p>
</div>
]]></field>
            <field name="report_template_ids" eval="[(6, 0, [ref('crfp_pricing.action_report_crfp_quotation')])]"/>
            <field name="auto_delete" eval="False"/>
        </record>
    </data>
</odoo>
