<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_activate_weekly_prices" model="ir.cron">
            <field name="name">CRFP: Activate Weekly Price Lists (Thursday)</field>
            <field name="model_id" ref="model_crfp_price_list"/>
            <field name="state">code</field>
            <field name="code">model.action_auto_activate_prices()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <!-- First run set to a Thursday at 06:00 -->
            <field name="nextcall">2025-01-02 06:00:00</field>
            <field name="active" eval="True"/>
        </record>
        <record id="ir_cron_field_buyer_reminders" model="ir.cron">
            <field name="name">CRFP: Recordatorio semanal a compradores de campo (Miércoles)</field>
            <field name="model_id" ref="crfp_pricing.model_crfp_field_buyer"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_field_buyer_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <!-- Next Wednesday at 06:00 UTC (midnight Costa Rica = UTC-6, so 06:00 UTC = 00:00 CR) -->
            <field name="nextcall">2026-04-08 12:00:00</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
