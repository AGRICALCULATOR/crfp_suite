<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Weekly cron: analyze client buying patterns and flag overdue accounts -->
    <record id="cron_crfp_reorder_analysis" model="ir.cron">
        <field name="name">CR Farm: AI Reorder Pattern Analysis</field>
        <field name="model_id" ref="crfp_pricing.model_crfp_reorder_analysis"/>
        <field name="state">code</field>
        <field name="code">model._cron_run_reorder_analysis()</field>
        <field name="interval_number">7</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="priority">10</field>
    </record>

</odoo>
