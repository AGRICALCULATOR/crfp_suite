<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="crfp_pricing.ConfirmOrder">
        <div class="crfp-confirm-tab">
            <div class="crfp-tab-header">
                <div>
                    <h2><i class="fa fa-clipboard-check"/> Confirm Order &amp; Create Sale Order</h2>
                    <p class="crfp-subtitle">Load a saved quotation, enter pallets, create Sale Order in Odoo</p>
                </div>
            </div>

            <!-- Step 1: Load quotation -->
            <div class="crfp-step-card">
                <div class="crfp-step-num">1</div>
                <div class="crfp-step-content">
                    <label>Load Price Quotation</label>
                    <select class="crfp-select-full" t-on-change="onQuotationSelect">
                        <option value="">-- Select a saved quotation --</option>
                        <t t-foreach="props.quotations" t-as="q" t-key="q.id">
                            <option t-att-value="q.id" t-esc="q.name + ' (' + (q.incoterm || '') + ')'"/>
                        </t>
                    </select>
                </div>
            </div>

            <!-- Step 2: Client -->
            <div class="crfp-step-card">
                <div class="crfp-step-num">2</div>
                <div class="crfp-step-content">
                    <label>Client / Contact</label>
                    <select class="crfp-select-full" t-model.number="state.selectedPartnerId">
                        <option value="">-- Select client --</option>
                        <t t-foreach="props.partners" t-as="p" t-key="p.id">
                            <option t-att-value="p.id" t-esc="p.name"/>
                        </t>
                    </select>
                </div>
            </div>

            <!-- Step 3: Products & pallets -->
            <t t-if="props.lines.length">
                <div class="crfp-step-card">
                    <div class="crfp-step-num">3</div>
                    <div class="crfp-step-content">
                        <label>Products &amp; Pallets</label>
                        <table class="crfp-rtbl">
                            <thead><tr>
                                <th>Product</th>
                                <th>Price/Box</th>
                                <th>Boxes/Pallet</th>
                                <th>Pallets</th>
                                <th>Total Boxes</th>
                                <th>Line Total</th>
                            </tr></thead>
                            <tbody>
                                <t t-foreach="props.lines" t-as="l" t-key="l.crfp_product_id">
                                    <t t-if="l.include_in_pdf">
                                        <tr>
                                            <td t-esc="l.product_name"/>
                                            <td class="crfp-mono" t-esc="'$' + fmt(l.final_price)"/>
                                            <td class="crfp-mono" t-esc="l.boxes_per_pallet"/>
                                            <td>
                                                <input type="number" class="crfp-pallet-input" min="0"
                                                       t-att-value="l.pallets"
                                                       t-on-change="(ev) => this.onPallet(l.crfp_product_id, ev)"/>
                                            </td>
                                            <td class="crfp-mono" t-esc="l.pallets * l.boxes_per_pallet"/>
                                            <td class="crfp-mono" t-esc="'$' + fmt(l.pallets * l.boxes_per_pallet * l.final_price)"/>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                            <tfoot><tr class="crfp-total-row">
                                <td colspan="4"><strong>TOTAL</strong></td>
                                <td class="crfp-mono"><strong t-esc="totalBoxes"/></td>
                                <td class="crfp-mono"><strong t-esc="'$' + fmt(totalAmount)"/></td>
                            </tr></tfoot>
                        </table>
                    </div>
                </div>

                <div class="crfp-confirm-actions">
                    <button class="btn btn-primary btn-lg"
                            t-att-disabled="state.creating || !state.selectedPartnerId"
                            t-on-click="onCreate">
                        <i class="fa fa-check-circle"/>
                        <t t-if="state.creating"> Creating...</t>
                        <t t-else=""> Create Sale Order in Odoo</t>
                    </button>
                </div>
            </t>
        </div>
    </t>
</templates>
