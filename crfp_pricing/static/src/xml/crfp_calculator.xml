<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="crfp_pricing.CrfpCalculator">
        <div class="crfp-app">
            <t t-if="state.loading">
                <div class="crfp-loading"><i class="fa fa-spinner fa-spin fa-3x"/><p>Loading CR Farm Calculator...</p></div>
            </t>
            <t t-else="">
                <!-- ═══ HEADER ═══ -->
                <header class="crfp-header">
                    <div class="crfp-logo-area">
                        <i class="fa fa-leaf crfp-logo-icon"/>
                        <div><h1>AgriPrice Calculator</h1><p>CR FARM PRODUCTS VYM S.A</p></div>
                    </div>
                    <div class="crfp-hdr-right">
                        <div class="crfp-inc-badge">
                            <span t-esc="state.incoterm"/> · <span t-esc="portDisplay"/>
                        </div>
                        <div class="crfp-hdr-client">
                            <div class="crfp-client-search-wrap">
                                <input type="text"
                                       class="crfp-client-input"
                                       t-att-value="state.partnerSearchText"
                                       t-on-input="onPartnerSearch"
                                       t-on-focus="onPartnerFocus"
                                       t-on-blur="onPartnerBlur"
                                       placeholder="Search client..."/>
                                <t t-if="state.partnerId">
                                    <button class="crfp-client-clear" t-on-mousedown.prevent="clearPartner">✕</button>
                                </t>
                                <div class="crfp-client-dropdown" t-if="state.showPartnerDropdown">
                                    <t t-if="filteredPartners.length === 0">
                                        <div class="crfp-client-empty">No contacts found</div>
                                    </t>
                                    <t t-foreach="filteredPartners" t-as="p" t-key="p.id">
                                        <div class="crfp-client-option"
                                             t-att-class="{'crfp-client-selected': p.id === state.partnerId}"
                                             t-on-mousedown.prevent="() => this.selectPartner(p)">
                                            <span class="crfp-client-name" t-esc="p.name"/>
                                            <span class="crfp-client-email" t-if="p.email" t-esc="p.email"/>
                                            <span class="crfp-client-badge" t-if="p.is_company">Company</span>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                        <div class="crfp-list-mgr">
                            <input type="text" t-att-value="state.quotationName" placeholder="Quotation Name" t-on-change="onQuotationNameChange"/>
                            <button class="crfp-list-btn crfp-btn-refresh" t-if="state.quotationId" t-on-click="refreshQuotation" title="Duplicate quotation with today's exchange rate and current raw material prices">
                                <i class="fa fa-sync-alt"/> Actualizar
                            </button>
                            <button class="crfp-list-btn" t-on-click="saveQuotation"><i class="fa fa-save"/> Guardar</button>
                            <button class="crfp-list-btn crfp-btn-new" t-on-click="newQuotation"><i class="fa fa-plus"/> Nuevo</button>
                        </div>
                    </div>
                </header>

                <!-- ═══ MAIN LAYOUT: Sidebar + Cards ═══ -->
                <div class="crfp-calc-layout">
                    <!-- ─── SIDEBAR ─── -->
                    <aside class="crfp-sidebar">
                        <!-- Global Parameters -->
                        <div class="crfp-sb-sec">
                            <div class="crfp-sb-hdr" t-on-click="() => this.toggleSection('global')">
                                <span><i class="fa fa-sliders-h"/> Global Parameters</span>
                                <i t-att-class="state.sections.global ? 'fa fa-chevron-up' : 'fa fa-chevron-down'"/>
                            </div>
                            <div class="crfp-sb-body" t-if="state.sections.global">
                                <div class="crfp-pg">
                                    <label><i class="fa fa-exchange-alt"/> Exchange Rate (CRC / $1)</label>
                                    <input type="number" step="0.01" t-att-value="state.exchangeRate" t-on-input="onExchangeRateChange"/>
                                </div>
                                <div class="crfp-pg">
                                    <label><i class="fa fa-handshake"/> Incoterm 2020</label>
                                    <select t-on-change="onIncotermChange">
                                        <t t-foreach="['EXW','FCA','FOB','CFR','CIF','CPT','CIP','DAP','DDP']" t-as="inc" t-key="inc">
                                            <option t-att-value="inc" t-att-selected="inc === state.incoterm" t-esc="inc"/>
                                        </t>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Freight Route -->
                        <div class="crfp-sb-sec">
                            <div class="crfp-sb-hdr" t-on-click="() => this.toggleSection('freight')">
                                <span><i class="fa fa-ship"/> Freight Route</span>
                                <i t-att-class="state.sections.freight ? 'fa fa-chevron-up' : 'fa fa-chevron-down'"/>
                            </div>
                            <div class="crfp-sb-body" t-if="state.sections.freight">
                                <div class="crfp-pg">
                                    <label><i class="fa fa-anchor"/> Destination Port</label>
                                    <select t-on-change="onPortChange">
                                        <option value="">-- Select port --</option>
                                        <t t-foreach="state.ports" t-as="p" t-key="p.id">
                                            <option t-att-value="p.id" t-att-selected="p.id === state.portId"
                                                    t-esc="p.code + ' - ' + p.name + ' (' + p.country + ')'"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="crfp-pg">
                                    <label><i class="fa fa-boxes"/> Total Boxes in Container</label>
                                    <input type="number" t-att-value="state.totalBoxes" t-on-change="onTotalBoxesChange" class="crfp-mono crfp-bold"/>
                                </div>
                                <div class="crfp-pg">
                                    <label><i class="fa fa-ship"/> Active Freight Quote</label>
                                    <select t-on-change="onFreightQuoteChange">
                                        <option value="">-- No quote --</option>
                                        <t t-foreach="state.freightQuotes" t-as="fq" t-key="fq.id">
                                            <option t-att-value="fq.id" t-att-selected="fq.id === state.freightQuoteId"
                                                    t-esc="(fq.carrier_name || '') + ' — $' + (fq.all_in_freight || 0).toFixed(0) + ' (' + ((fq.port_id &amp;&amp; fq.port_id[1]) || '') + ')'"/>
                                        </t>
                                    </select>
                                </div>
                                <!-- Logistics summary -->
                                <div class="crfp-log-sum" t-if="logSummary.frTotal > 0">
                                    <div class="crfp-lr"><span>Freight</span><span t-esc="'$' + fmt(logSummary.frTotal)"/></div>
                                    <div class="crfp-lr"><span>Transport</span><span t-esc="'$' + fmt(logSummary.tUSD)"/></div>
                                    <div class="crfp-lr"><span>THC Origin</span><span t-esc="'$' + fmt(logSummary.poUSD)"/></div>
                                    <div class="crfp-lr"><span>Fumigation</span><span t-esc="'$' + fmt(logSummary.fuUSD)"/></div>
                                    <div class="crfp-lr"><span>Broker</span><span t-esc="'$' + fmt(logSummary.agUSD)"/></div>
                                    <div class="crfp-lr crfp-lr-total">
                                        <span>Per Box</span>
                                        <span t-esc="'$' + fmt(logSummary.frPB + logSummary.tPB + logSummary.poPB + logSummary.fuPB + logSummary.agPB, 4)"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ★ OPERATION COSTS (per container, editable per quotation) ★ -->
                        <div class="crfp-sb-sec">
                            <div class="crfp-sb-hdr" t-on-click="() => this.toggleSection('opCosts')">
                                <span><i class="fa fa-dollar-sign"/> Operation Costs ($/container)</span>
                                <i t-att-class="state.sections.opCosts ? 'fa fa-chevron-up' : 'fa fa-chevron-down'"/>
                            </div>
                            <div class="crfp-sb-body" t-if="state.sections.opCosts">
                                <div class="crfp-opcost-note">
                                    Your CR operation costs. Edit per quotation.
                                    <span t-if="state.freightQuoteId" class="crfp-opcost-fq-note">
                                        Costs marked <span class="crfp-fq-tag">FQ</span> are included in the freight quote.
                                    </span>
                                </div>
                                <div class="crfp-opcost-grid">
                                    <div class="crfp-opcost-row">
                                        <label>Transport Internal</label>
                                        <div class="crfp-opcost-input-wrap">
                                            <input type="number" t-att-value="state.fc.fc_transport"
                                                   t-on-change="(ev) => this.onFcChange('fc_transport', ev)" class="crfp-mono"/>
                                            <span class="crfp-fq-tag" t-if="activeQuoteIncludes('inc_transport')">FQ</span>
                                        </div>
                                    </div>
                                    <div class="crfp-opcost-row">
                                        <label>THC Origin</label>
                                        <div class="crfp-opcost-input-wrap">
                                            <input type="number" t-att-value="state.fc.fc_thc_origin"
                                                   t-on-change="(ev) => this.onFcChange('fc_thc_origin', ev)" class="crfp-mono"/>
                                            <span class="crfp-fq-tag" t-if="activeQuoteIncludes('inc_thc_origin')">FQ</span>
                                        </div>
                                    </div>
                                    <div class="crfp-opcost-row">
                                        <label>Fumigation CR</label>
                                        <div class="crfp-opcost-input-wrap">
                                            <input type="number" t-att-value="state.fc.fc_fumigation"
                                                   t-on-change="(ev) => this.onFcChange('fc_fumigation', ev)" class="crfp-mono"/>
                                        </div>
                                    </div>
                                    <div class="crfp-opcost-row">
                                        <label>Customs Broker</label>
                                        <div class="crfp-opcost-input-wrap">
                                            <input type="number" t-att-value="state.fc.fc_broker"
                                                   t-on-change="(ev) => this.onFcChange('fc_broker', ev)" class="crfp-mono"/>
                                            <span class="crfp-fq-tag" t-if="activeQuoteIncludes('inc_broker')">FQ</span>
                                        </div>
                                    </div>
                                    <div class="crfp-opcost-row">
                                        <label>THC Destination</label>
                                        <div class="crfp-opcost-input-wrap">
                                            <input type="number" t-att-value="state.fc.fc_thc_dest"
                                                   t-on-change="(ev) => this.onFcChange('fc_thc_dest', ev)" class="crfp-mono"/>
                                            <span class="crfp-fq-tag" t-if="activeQuoteIncludes('inc_thc_dest')">FQ</span>
                                        </div>
                                    </div>
                                    <div class="crfp-opcost-row">
                                        <label>Fumig. Destination</label>
                                        <div class="crfp-opcost-input-wrap">
                                            <input type="number" t-att-value="state.fc.fc_fumig_dest"
                                                   t-on-change="(ev) => this.onFcChange('fc_fumig_dest', ev)" class="crfp-mono"/>
                                            <span class="crfp-fq-tag" t-if="activeQuoteIncludes('inc_fumig_dest')">FQ</span>
                                        </div>
                                    </div>
                                    <div class="crfp-opcost-row">
                                        <label>Inland Delivery Dest.</label>
                                        <div class="crfp-opcost-input-wrap">
                                            <input type="number" t-att-value="state.fc.fc_inland_dest"
                                                   t-on-change="(ev) => this.onFcChange('fc_inland_dest', ev)" class="crfp-mono"/>
                                            <span class="crfp-fq-tag" t-if="activeQuoteIncludes('inc_inland_dest')">FQ</span>
                                        </div>
                                    </div>
                                    <div class="crfp-opcost-row">
                                        <label>Insurance (% EXW)</label>
                                        <div class="crfp-opcost-input-wrap">
                                            <input type="number" step="0.01" t-att-value="state.fc.fc_insurance_pct"
                                                   t-on-change="(ev) => this.onFcChange('fc_insurance_pct', ev)" class="crfp-mono"/>
                                        </div>
                                    </div>
                                    <div class="crfp-opcost-row">
                                        <label>Duties (% CIF) — DDP</label>
                                        <div class="crfp-opcost-input-wrap">
                                            <input type="number" step="0.1" t-att-value="state.fc.fc_duties_pct"
                                                   t-on-change="(ev) => this.onFcChange('fc_duties_pct', ev)" class="crfp-mono"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="crfp-opcost-total" t-if="logSummary">
                                    <span>Total logistics/box:</span>
                                    <span class="crfp-mono crfp-bold" t-esc="'$' + fmt(logSummary.frPB + logSummary.tPB + logSummary.poPB + logSummary.fuPB + logSummary.agPB + logSummary.tdPB + logSummary.fdPB + logSummary.dePB, 4)"/>
                                </div>
                            </div>
                        </div>

                        <!-- ★ BASE PRICES — single source of truth ★ -->
                        <div class="crfp-sb-sec">
                            <div class="crfp-sb-hdr" t-on-click="() => this.toggleSection('basePrices')">
                                <span><i class="fa fa-tags"/> Base Prices (CRC)</span>
                                <i t-att-class="state.sections.basePrices ? 'fa fa-chevron-up' : 'fa fa-chevron-down'"/>
                            </div>
                            <div class="crfp-sb-body" t-if="state.sections.basePrices">
                                <t t-foreach="categories" t-as="cat" t-key="cat">
                                    <div class="crfp-bp-cat" t-esc="getCatLabel(cat)"/>
                                    <t t-foreach="getLinesByCat(cat)" t-as="line" t-key="line.crfp_product_id">
                                        <div class="crfp-bp-row">
                                            <label t-esc="line.product_name"/>
                                            <input type="number" t-att-value="line.raw_price_crc"
                                                   t-on-change="(ev) => this.onBasePriceChange(line.crfp_product_id, ev)"
                                                   class="crfp-mono"/>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </div>

                        <!-- Saved Quotations -->
                        <div class="crfp-sb-sec">
                            <div class="crfp-sb-hdr" t-on-click="() => this.toggleSection('history')">
                                <span><i class="fa fa-history"/> Saved Quotations</span>
                                <i t-att-class="state.sections.history ? 'fa fa-chevron-up' : 'fa fa-chevron-down'"/>
                            </div>
                            <div class="crfp-sb-body" t-if="state.sections.history">
                                <t t-foreach="state.quotations" t-as="q" t-key="q.id">
                                    <div class="crfp-hist-item" t-att-class="{'active': q.id === state.quotationId}">
                                        <div class="crfp-hist-top" t-on-click="() => this.loadQuotation(q.id)">
                                            <strong t-esc="q.name"/>
                                            <span class="crfp-hdate" t-esc="q.create_date"/>
                                        </div>
                                        <button class="crfp-hist-open" t-if="q.id === state.quotationId"
                                                t-on-click="() => this.openQuotationForm(q.id)">
                                            <i class="fa fa-external-link-alt"/> Open in Quotations
                                        </button>
                                    </div>
                                </t>
                                <t t-if="!state.quotations.length">
                                    <div class="crfp-empty-small">No saved quotations yet</div>
                                </t>
                            </div>
                        </div>
                    </aside>

                    <!-- ─── PRODUCT CARDS (main area) ─── -->
                    <main class="crfp-calc-main">
                        <div class="crfp-sec-hdr">
                            <h2 t-esc="state.quotationName || 'New Quotation'"/>
                            <button class="crfp-toggle-view" t-on-click="toggleCompact">
                                <i class="fa fa-th-large"/> Toggle View
                            </button>
                        </div>
                        <t t-foreach="categories" t-as="cat" t-key="cat">
                            <t t-set="catLines" t-value="getLinesByCat(cat)"/>
                            <t t-if="catLines.length">
                                <div class="crfp-cat-hdr">
                                    <i t-att-class="'fa ' + getCatIcon(cat)"/>
                                    <span t-esc="getCatLabel(cat)"/>
                                    <span class="crfp-cat-count" t-esc="'(' + catLines.length + ')'"/>
                                </div>
                                <div t-att-class="state.compactView ? 'crfp-pgrid crfp-compact' : 'crfp-pgrid'">
                                    <t t-foreach="catLines" t-as="line" t-key="line.crfp_product_id">
                                        <ProductCard line="line" boxTypes="state.boxTypes"
                                                     onUpdate="(pid, f, v) => this.updateLine(pid, f, v)"
                                                     onToggleInclude="(pid) => this.toggleInclude(pid)"/>
                                    </t>
                                </div>
                            </t>
                        </t>
                    </main>
                </div>

                <!-- ═══ BOTTOM ACTIONS ═══ -->
                <div class="crfp-actions">
                    <button class="crfp-btn crfp-btn-calc" t-on-click="recalcAll"><i class="fa fa-sync-alt"/> Recalcular</button>
                    <button class="crfp-btn crfp-btn-save" t-on-click="saveQuotation"><i class="fa fa-save"/> Guardar Cotización</button>
                    <button class="crfp-btn crfp-btn-open" t-if="state.quotationId" t-on-click="() => this.openQuotationForm()">
                        <i class="fa fa-file-alt"/> Abrir Cotización
                    </button>
                </div>
            </t>
        </div>
    </t>
</templates>
