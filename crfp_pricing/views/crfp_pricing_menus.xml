<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client Action: the Owl Calculator -->
    <record id="action_crfp_calculator" model="ir.actions.client">
        <field name="name">Price Calculator</field>
        <field name="tag">crfp_pricing.calculator</field>
    </record>

    <!-- ═══ ROOT APP MENU ═══ -->
    <menuitem id="menu_crfp_pricing_root"
              name="CR Farm Export"
              action="action_crfp_calculator"
              web_icon="crfp_pricing,static/description/icon.png"
              sequence="5"/>

    <!-- Calculator -->
    <menuitem id="menu_crfp_calculator"
              name="Calculator"
              parent="menu_crfp_pricing_root"
              action="action_crfp_calculator"
              sequence="10"/>

    <!-- Quotations -->
    <menuitem id="menu_crfp_quotations"
              name="Quotations"
              parent="menu_crfp_pricing_root"
              action="action_crfp_quotation"
              sequence="20"/>

    <!-- Freight Quotes -->
    <menuitem id="menu_crfp_freight_quotes"
              name="Freight Quotes"
              parent="menu_crfp_pricing_root"
              action="action_crfp_freight_quote"
              sequence="30"/>

    <!-- Price Lists -->
    <menuitem id="menu_crfp_price_lists"
              name="Price Lists"
              parent="menu_crfp_pricing_root"
              action="action_crfp_price_list"
              sequence="40"/>

    <!-- Price Trends -->
    <menuitem id="menu_crfp_price_trends"
              name="Price Trends"
              parent="menu_crfp_pricing_root"
              action="action_crfp_price_history"
              sequence="50"/>

    <!-- Field Buyers -->
    <menuitem id="menu_crfp_field_buyers"
              name="Field Buyers"
              parent="menu_crfp_pricing_root"
              action="action_crfp_field_buyer"
              sequence="60"/>

    <!-- Configuration -->
    <menuitem id="menu_crfp_pricing_config"
              name="Configuration"
              parent="menu_crfp_pricing_root"
              sequence="90"/>

    <menuitem id="menu_crfp_pc_ports" name="Ports"
              parent="menu_crfp_pricing_config" action="crfp_base.action_crfp_port" sequence="10"/>
    <menuitem id="menu_crfp_pc_containers" name="Container Types"
              parent="menu_crfp_pricing_config" action="crfp_base.action_crfp_container_type" sequence="30"/>
    <menuitem id="menu_crfp_pc_products" name="Export Products"
              parent="menu_crfp_pricing_config" action="crfp_base.action_crfp_product" sequence="40"/>
    <menuitem id="menu_crfp_pc_boxes" name="Box Types"
              parent="menu_crfp_pricing_config" action="crfp_base.action_crfp_box_type" sequence="50"/>
    <menuitem id="menu_crfp_pc_pallets" name="Pallet Configuration"
              parent="menu_crfp_pricing_config" action="crfp_base.action_crfp_pallet_config" sequence="60"/>
    <menuitem id="menu_crfp_pc_incoterms" name="Incoterm Matrix"
              parent="menu_crfp_pricing_config" action="crfp_base.action_crfp_incoterm_matrix" sequence="70"/>
    <menuitem id="menu_crfp_pc_settings" name="Settings"
              parent="menu_crfp_pricing_config" action="crfp_base.action_open_crfp_settings" sequence="80"/>
</odoo>
