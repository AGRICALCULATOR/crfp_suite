<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crfp_freight_quote_tree" model="ir.ui.view">
        <field name="name">crfp.freight.quote.tree</field>
        <field name="model">crfp.freight.quote</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="carrier_partner_id" string="Carrier"/>
                <field name="port_id"/>
                <field name="all_in_freight"/>
                <field name="transit_days"/>
                <field name="valid_until"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'expired'"/>
            </list>
        </field>
    </record>

    <record id="crfp_freight_quote_form" model="ir.ui.view">
        <field name="name">crfp.freight.quote.form</field>
        <field name="model">crfp.freight.quote</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" type="object" string="Activate"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_expire" type="object" string="Mark Expired"
                            invisible="state != 'active'"/>
                    <button name="action_request_update" type="object"
                            string="Request Updated Quote"
                            class="btn-secondary"
                            invisible="state != 'expired'"
                            icon="fa-envelope"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Quote Info">
                            <field name="name"/>
                            <field name="carrier_partner_id" string="Carrier / Forwarder"
                                   options="{'no_create': True}"
                                   help="Select the carrier from your Odoo contacts"/>
                            <field name="port_id"/>
                            <field name="container_type_id"/>
                            <field name="delivery_type"/>
                        </group>
                        <group string="Pricing &amp; Schedule">
                            <field name="all_in_freight"/>
                            <field name="transit_days"/>
                            <field name="routing"/>
                            <field name="transship_port" invisible="routing != 'transship'"/>
                            <field name="valid_from"/>
                            <field name="valid_until"/>
                            <field name="source"/>
                        </group>
                    </group>
                    <group string="What is INCLUDED in this freight">
                        <group>
                            <field name="inc_transport"/>
                            <field name="inc_thc_origin"/>
                            <field name="inc_broker"/>
                        </group>
                        <group>
                            <field name="inc_thc_dest"/>
                            <field name="inc_inland_dest"/>
                            <field name="inc_fumig_dest"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_crfp_freight_quote" model="ir.actions.act_window">
        <field name="name">Freight Quotes</field>
        <field name="res_model">crfp.freight.quote</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
