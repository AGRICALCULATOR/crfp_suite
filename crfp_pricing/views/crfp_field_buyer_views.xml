<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ TREE VIEW ═══ -->
    <record id="view_crfp_field_buyer_tree" model="ir.ui.view">
        <field name="name">crfp.field.buyer.tree</field>
        <field name="model">crfp.field.buyer</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id" optional="show"/>
                <field name="portal_url" widget="CopyClipboardChar" string="Link"/>
                <button name="action_open_portal_preview" type="object"
                        string="Abrir" icon="fa-external-link"
                        title="Vista previa del portal"/>
                <field name="last_accessed" optional="show"/>
                <field name="access_count" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ═══ FORM VIEW ═══ -->
    <record id="view_crfp_field_buyer_form" model="ir.ui.view">
        <field name="name">crfp.field.buyer.form</field>
        <field name="model">crfp.field.buyer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_copy_link" type="object"
                            string="Copiar Link" class="btn-primary"
                            icon="fa-clipboard"/>
                    <button name="action_open_portal_preview" type="object"
                            string="Vista Previa" class="btn-secondary"
                            icon="fa-external-link"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre del comprador..."/></h1>
                    </div>
                    <group>
                        <group string="Info del Comprador">
                            <field name="partner_id"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Acceso">
                            <field name="token"/>
                            <field name="portal_url" widget="CopyClipboardChar"
                                   string="Link del Portal"/>
                            <button name="action_regenerate_token" type="object"
                                    string="Regenerar Token" class="btn-secondary"
                                    confirm="Esto invalidará el link actual. ¿Continuar?"
                                    icon="fa-refresh"/>
                        </group>
                    </group>
                    <group>
                        <group string="Estadísticas de Uso">
                            <field name="last_accessed"/>
                            <field name="access_count"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notas sobre este comprador..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ ACTION ═══ -->
    <record id="action_crfp_field_buyer" model="ir.actions.act_window">
        <field name="name">Compradores de Campo</field>
        <field name="res_model">crfp.field.buyer</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Agregar primer comprador de campo
            </p>
            <p>
                Cree tokens de acceso para compradores de campo. Cada comprador
                recibe un link único para ingresar precios de materia prima desde
                su celular — sin necesidad de login.
            </p>
        </field>
    </record>
</odoo>
