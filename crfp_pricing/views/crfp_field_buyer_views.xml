<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List view ── -->
    <record id="view_crfp_field_buyer_tree" model="ir.ui.view">
        <field name="name">crfp.field.buyer.tree</field>
        <field name="model">crfp.field.buyer</field>
        <field name="arch" type="xml">
            <list string="Field Buyers" decoration-muted="not active">
                <field name="name"/>
                <field name="phone"/>
                <field name="partner_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ── -->
    <record id="view_crfp_field_buyer_form" model="ir.ui.view">
        <field name="name">crfp.field.buyer.form</field>
        <field name="model">crfp.field.buyer</field>
        <field name="arch" type="xml">
            <form string="Field Buyer">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_regenerate_token" type="object"
                                string="Regenerate Token" class="btn-secondary"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="phone"/>
                            <field name="partner_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="token" readonly="1"/>
                            <field name="public_url" readonly="1" widget="url" string="Link de Precios"/>
                        </group>
                    </group>
                    <div class="o_field_widget mb-3 ms-2">
                        <button name="action_copy_link" type="object"
                                string="Copiar Link" class="btn btn-primary"
                                invisible="not token"/>
                    </div>
                    <notebook>
                        <page string="Allowed Products">
                            <field name="allowed_product_ids" widget="many2many_tags" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search view ── -->
    <record id="view_crfp_field_buyer_search" model="ir.ui.view">
        <field name="name">crfp.field.buyer.search</field>
        <field name="model">crfp.field.buyer</field>
        <field name="arch" type="xml">
            <search string="Field Buyers">
                <field name="name"/>
                <field name="phone"/>
                <filter name="filter_active"   string="Active"   domain="[('active','=',True)]"/>
                <filter name="filter_inactive" string="Archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- ── Window action ── -->
    <record id="action_crfp_field_buyer" model="ir.actions.act_window">
        <field name="name">Field Buyers</field>
        <field name="res_model">crfp.field.buyer</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your first field buyer!</p>
        </field>
    </record>

</odoo>
