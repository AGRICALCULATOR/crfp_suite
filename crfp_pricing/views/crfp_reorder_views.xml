<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ Reorder Analysis — List ═══ -->
    <record id="crfp_reorder_analysis_list" model="ir.ui.view">
        <field name="name">crfp.reorder.analysis.list</field>
        <field name="model">crfp.reorder.analysis</field>
        <field name="arch" type="xml">
            <list string="AI Reorder Analysis"
                  default_order="days_overdue desc"
                  decoration-danger="status in ('overdue','inactive')"
                  decoration-warning="status == 'due_soon'"
                  decoration-success="status == 'active'"
                  decoration-info="status == 'new'">
                <field name="partner_id"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-warning="status == 'due_soon'"
                       decoration-danger="status in ('overdue','inactive')"
                       decoration-info="status == 'new'"/>
                <field name="order_count"/>
                <field name="last_order_date"/>
                <field name="avg_interval_days" string="Avg Interval (days)"/>
                <field name="expected_next_order"/>
                <field name="days_overdue" string="Days Overdue"/>
                <field name="last_products" optional="show"/>
                <field name="total_revenue_usd" string="Revenue (USD)" optional="show"/>
                <field name="activity_created" optional="show"/>
                <field name="email_sent" optional="show"/>
                <field name="last_analysis_date" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ═══ Reorder Analysis — Form ═══ -->
    <record id="crfp_reorder_analysis_form" model="ir.ui.view">
        <field name="name">crfp.reorder.analysis.form</field>
        <field name="model">crfp.reorder.analysis</field>
        <field name="arch" type="xml">
            <form string="Client Reorder Analysis">
                <header>
                    <button name="action_generate_ai_insights" type="object"
                            string="Generate AI Insights" class="btn-primary"
                            icon="fa-magic"/>
                    <button name="action_create_activity" type="object"
                            string="Create Sales Activity" class="btn-secondary"
                            invisible="activity_created"/>
                    <button name="action_send_reactivation_email" type="object"
                            string="Send Reactivation Email" class="btn-secondary"
                            invisible="not ai_email_subject or email_sent"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="new,active,due_soon,overdue,inactive"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="partner_id"/>
                        <h1><field name="partner_id" placeholder="Client Partner"/></h1>
                    </div>

                    <group>
                        <group string="Buying Pattern">
                            <field name="order_count"/>
                            <field name="first_order_date"/>
                            <field name="last_order_date"/>
                            <field name="avg_interval_days"/>
                            <field name="last_products"/>
                            <field name="total_revenue_usd" widget="monetary"
                                   options="{'currency_field': False}"/>
                        </group>
                        <group string="Reorder Prediction">
                            <field name="expected_next_order"/>
                            <field name="days_overdue"/>
                            <field name="activity_created"/>
                            <field name="last_activity_date"/>
                            <field name="email_sent"/>
                            <field name="email_sent_date"/>
                            <field name="last_analysis_date"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="AI Insights" name="ai_insights">
                            <group>
                                <field name="ai_last_run" readonly="1"/>
                            </group>
                            <field name="ai_insights" placeholder="Run 'Generate AI Insights' to populate this field..."/>
                        </page>
                        <page string="AI Reactivation Email" name="ai_email">
                            <group>
                                <field name="ai_email_subject" placeholder="Email subject will be generated by Claude..."/>
                            </group>
                            <field name="ai_email_body" widget="html"
                                   placeholder="Email body will be generated by Claude..."/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ Reorder Analysis — Search ═══ -->
    <record id="crfp_reorder_analysis_search" model="ir.ui.view">
        <field name="name">crfp.reorder.analysis.search</field>
        <field name="model">crfp.reorder.analysis</field>
        <field name="arch" type="xml">
            <search string="Reorder Analysis">
                <field name="partner_id"/>
                <filter string="Overdue" name="overdue"
                        domain="[('status','in',('overdue','inactive'))]"/>
                <filter string="Due Soon" name="due_soon"
                        domain="[('status','=','due_soon')]"/>
                <filter string="Active Clients" name="active"
                        domain="[('status','=','active')]"/>
                <filter string="No Activity Created" name="no_activity"
                        domain="[('activity_created','=',False),('status','in',('overdue','inactive','due_soon'))]"/>
                <filter string="Email Not Sent" name="no_email"
                        domain="[('email_sent','=',False),('ai_email_subject','!=',False)]"/>
                <group by="status" string="Status"/>
                <group by="partner_id" string="Client"/>
            </search>
        </field>
    </record>

    <!-- ═══ Reorder Analysis — Kanban ═══ -->
    <record id="crfp_reorder_analysis_kanban" model="ir.ui.view">
        <field name="name">crfp.reorder.analysis.kanban</field>
        <field name="model">crfp.reorder.analysis</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="partner_id"/>
                <field name="status"/>
                <field name="days_overdue"/>
                <field name="avg_interval_days"/>
                <field name="last_order_date"/>
                <field name="activity_created"/>
                <field name="email_sent"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <strong><field name="partner_id"/></strong>
                                <div class="o_kanban_tags_section mt-1">
                                    <t t-if="record.days_overdue.raw_value > 0">
                                        <span class="badge bg-danger">
                                            <t t-esc="record.days_overdue.value"/> days overdue
                                        </span>
                                    </t>
                                    <t t-if="record.activity_created.raw_value">
                                        <span class="badge bg-secondary ms-1">Activity ✓</span>
                                    </t>
                                    <t t-if="record.email_sent.raw_value">
                                        <span class="badge bg-info ms-1">Email ✓</span>
                                    </t>
                                </div>
                                <div class="text-muted small mt-2">
                                    Avg interval: <t t-esc="record.avg_interval_days.value"/> days<br/>
                                    Last order: <t t-esc="record.last_order_date.value"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ Action ═══ -->
    <record id="action_crfp_reorder_analysis" model="ir.actions.act_window">
        <field name="name">AI Reorder Analysis</field>
        <field name="res_model">crfp.reorder.analysis</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_overdue': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No reorder analysis data yet
            </p>
            <p>
                The weekly cron will automatically analyze your clients' buying patterns
                and flag accounts that are overdue for a new order.
                You can also trigger analysis manually from Settings > Technical > Scheduled Actions.
            </p>
        </field>
    </record>

    <!-- ═══ Menu ═══ -->
    <menuitem id="menu_crfp_reorder_analysis"
              name="AI Reorder Analysis"
              parent="crfp_pricing.menu_crfp_pricing_root"
              action="action_crfp_reorder_analysis"
              sequence="90"/>

</odoo>
