<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_fp_fields" model="ir.ui.view">
        <field name="name">account.move.form.fp.fields</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_fp_send_to_api" string="Enviar a Hacienda" type="object" class="oe_highlight" invisible="not fp_is_electronic_invoice or fp_api_state != 'pending'"/>
                <button name="action_fp_consult_api_document" string="Consultar Hacienda" type="object" invisible="not fp_is_electronic_invoice or fp_api_state in ('done','error')"/>
            </xpath>
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="fp_is_electronic_invoice" invisible="1"/>
                <field
                    name="fp_document_type"
                    invisible="not fp_is_electronic_invoice or move_type in ('out_refund', 'in_invoice')"
                    readonly="fp_api_state != 'pending'"
                />
                <field
                    name="fp_document_type"
                    invisible="not fp_is_electronic_invoice or move_type != 'out_refund'"
                    readonly="1"
                />
                <field
                    name="fp_document_type"
                    invisible="not fp_is_electronic_invoice or move_type != 'in_invoice'"
                    readonly="1"
                />
                <field name="fp_economic_activity_id" invisible="not fp_is_electronic_invoice" readonly="fp_api_state != 'pending'"/>
                <field name="fp_sale_condition" invisible="not fp_is_electronic_invoice" readonly="fp_api_state != 'pending'"/>
                <field name="fp_payment_method" invisible="not fp_is_electronic_invoice" readonly="fp_api_state != 'pending'"/>
                <field name="fp_external_id" readonly="1" invisible="not fp_is_electronic_invoice"/>
                <field name="fp_api_state" readonly="1" invisible="1"/>
                <label for="fp_consecutive_number" invisible="not fp_is_electronic_invoice"/>
                <div class="o_row" invisible="not fp_is_electronic_invoice">
                    <field name="fp_consecutive_number" readonly="1" nolabel="1"/>
                    <button
                        name="action_fp_open_hacienda_documents"
                        type="object"
                        class="btn-link px-0 ms-1"
                        icon="fa-external-link"
                        invisible="not fp_consecutive_number"
                        title="Abrir documentos en Hacienda"
                    />
                </div>
                <field name="fp_invoice_status" readonly="1" invisible="not fp_is_electronic_invoice"/>
            </xpath>


            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='discount']" position="after">
                <field name="fp_discount_code" optional="hide" readonly="parent.fp_api_state != 'pending'"/>
                <field name="fp_discount_nature" optional="hide" readonly="parent.fp_api_state != 'pending'"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_subtotal']" position="after">
                <field name="fp_is_other_charge_line" string="Otro cargo FE" readonly="1" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/form//field[@name='discount']" position="after">
                <field name="fp_discount_code" readonly="parent.fp_api_state != 'pending'"/>
                <field name="fp_discount_nature" readonly="parent.fp_api_state != 'pending'" placeholder="Ej: Descuento general"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/form//field[@name='price_subtotal']" position="after">
                <field name="fp_is_other_charge_line" string="Otro cargo FE" readonly="1"/>
            </xpath>

            <xpath expr="//field[@name='tax_totals']" position="before">
                <field name="fp_total_other_charges" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1" invisible="not fp_is_electronic_invoice or fp_document_type not in ('FE', 'TE', 'NC')"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Otros Cargos FE" invisible="not fp_is_electronic_invoice or fp_document_type not in ('FE', 'TE', 'NC')">
                    <field name="fp_other_charge_line_ids" readonly="fp_api_state != 'pending'">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="calculation_type"/>
                                <field name="document_type"/>
                                <field name="detail"/>
                                <field name="document_type_other" invisible="document_type != '99'"/>
                                <field name="third_party_id" options="{'no_create': True}"/>
                                <field name="account_id" options="{'no_create': True}"/>
                                <field name="percentage" invisible="calculation_type != 'percentage'"/>
                                <field name="untaxed_base_amount" readonly="1"/>
                                <field name="amount_manual" invisible="calculation_type != 'amount'"/>
                                <field name="amount" readonly="1"/>
                            </list>
                            <form>
                                <group col="2">
                                    <field name="calculation_type"/>
                                    <field name="document_type"/>
                                    <field name="detail"/>
                                    <field name="document_type_other" invisible="document_type != '99'"/>
                                    <field name="third_party_id" options="{'no_create': True}"/>
                                    <field name="account_id" options="{'no_create': True}"/>
                                    <field name="percentage" invisible="calculation_type != 'percentage'"/>
                                    <field name="untaxed_base_amount" readonly="1"/>
                                    <field name="amount_manual" invisible="calculation_type != 'amount'"/>
                                    <field name="amount" readonly="1"/>
                                </group>
                            </form>
                        </field>
                </page>
                <page string="Información de referencia FE" invisible="fp_document_type not in ('NC', 'ND', 'FEC') or not fp_is_electronic_invoice">
                    <group col="2">
                        <field name="fp_reference_document_type" required="fp_document_type in ('NC', 'ND', 'FEC') and fp_is_electronic_invoice" readonly="fp_api_state != 'pending'"/>
                        <field name="fp_reference_number" required="fp_document_type in ('NC', 'ND', 'FEC') and fp_is_electronic_invoice" readonly="fp_api_state != 'pending'"/>
                        <field name="fp_reference_issue_datetime" required="fp_document_type in ('NC', 'ND', 'FEC') and fp_is_electronic_invoice" readonly="fp_api_state != 'pending'"/>
                        <field name="fp_reference_exchange_rate" invisible="currency_id == company_currency_id or fp_document_type not in ('NC', 'ND')" readonly="fp_api_state != 'pending'"/>
                        <field name="fp_reference_code" required="fp_document_type in ('NC', 'ND', 'FEC') and fp_is_electronic_invoice" readonly="fp_api_state != 'pending'"/>
                        <field name="fp_reference_reason" required="fp_document_type in ('NC', 'ND', 'FEC') and fp_is_electronic_invoice" readonly="fp_api_state != 'pending'"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_out_invoice_tree_fp_fields" model="ir.ui.view">
        <field name="name">account.move.list.out.invoice.fp.fields</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="fp_consecutive_number" string="Consecutivo" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='status_in_payment']" position="after">
                <field
                    name="fp_invoice_status"
                    string="Estado FE"
                    widget="badge"
                    decoration-success="fp_invoice_status == 'accepted'"
                    decoration-danger="fp_invoice_status == 'rejected'"
                    decoration-warning="fp_invoice_status == 'sent'"
                    optional="show"
                />
            </xpath>
        </field>
    </record>
</odoo>
