<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Router: always use the CR Farm custom template for ALL invoices/proformas -->
    <template id="report_invoice_document_fp_template_router" inherit_id="account.report_invoice_document">
        <xpath expr="//t[@t-call='web.external_layout']" position="before">
            <t
                t-call="l10n_cr_einvoice.report_invoice_document_fp_custom"
                t-lang="o.partner_id.lang or o.commercial_partner_id.lang or env.user.lang"
            />
        </xpath>
        <xpath expr="//t[@t-call='web.external_layout']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
    </template>

    <template id="report_invoice_document_fp_custom">
        <t t-call="web.html_container">
            <t t-set="fp_template_style" t-value="o.company_id.fp_invoice_template_style or 'modern_prohygiene'"/>
            <t
                t-set="fp_document_types"
                t-value="o._fp_get_selection_map('fp_document_type')"
            />
            <t t-set="fp_lines_to_report" t-value="o.invoice_line_ids"/>
            <t t-set="fp_product_lines" t-value="fp_lines_to_report.filtered_domain([('display_type', 'in', [False, 'product'])])"/>
            <t t-set="qr_code_url" t-value="o._generate_qr_code(silent_errors=True) if o.display_qr_code else False"/>
            <t t-set="fp_company_partner" t-value="o.company_id.partner_id"/>
            <t t-set="fp_receiver_partner" t-value="o.partner_id"/>
            <t t-set="fp_receiver_address" t-value="', '.join(filter(None, [fp_receiver_partner.street, fp_receiver_partner.fp_district_id.name if fp_receiver_partner.fp_district_id else False, fp_receiver_partner.fp_canton_id.name if fp_receiver_partner.fp_canton_id else False, fp_receiver_partner.fp_province_id.name if fp_receiver_partner.fp_province_id else False]))"/>
            <t t-set="fp_receiver_phone" t-value="fp_receiver_partner.phone or (fp_receiver_partner._fields.get('mobile') and fp_receiver_partner.mobile) or ''"/>
            <t t-set="fp_reference_value" t-value="o.reversed_entry_id.fp_consecutive_number if o.fp_document_type == 'NC' and o.reversed_entry_id else (o.ref or '-')"/>
            <t t-set="fp_summary_totals" t-value="o._fp_get_report_summary_totals()"/>
            <t t-set="fp_tax_rate_breakdown" t-value="o._fp_get_report_tax_rate_breakdown()"/>
            <t t-set="fp_electronic_key_value" t-value="o.fp_external_id if o._fields.get('fp_external_id') else '-'"/>
            <t t-set="fp_consecutive_value" t-value="o.fp_consecutive_number if o._fields.get('fp_consecutive_number') else '-'"/>
            <t t-set="fp_currency_rate_value" t-value="o.invoice_currency_rate if o._fields.get('invoice_currency_rate') and o.invoice_currency_rate else 1.0"/>
            <t t-set="fp_sale_condition_value" t-value="o.fp_sale_condition if o._fields.get('fp_sale_condition') and o.fp_sale_condition else (o.invoice_payment_term_id.name or '-')"/>
            <t t-set="fp_payment_method_value" t-value="o.fp_payment_method if o._fields.get('fp_payment_method') and o.fp_payment_method else '-'"/>
            <t t-set="fp_sale_condition_map" t-value="o._fp_get_selection_map('fp_sale_condition')"/>
            <t t-set="fp_payment_method_map" t-value="o._fp_get_selection_map('fp_payment_method')"/>
            <t t-set="fp_sale_condition_label" t-value="fp_sale_condition_map.get(o.fp_sale_condition, fp_sale_condition_value) if o._fields.get('fp_sale_condition') else fp_sale_condition_value"/>
            <t t-set="fp_payment_method_label" t-value="fp_payment_method_map.get(o.fp_payment_method, fp_payment_method_value) if o._fields.get('fp_payment_method') else fp_payment_method_value"/>
            <t t-set="fp_pdf_fill_style" t-value="'background: #f2f2f2 !important; background-color: #f2f2f2 !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important;'"/>

            <div class="page">
                <t t-if="fp_template_style == 'modern_prohygiene'">
                    <style>
                        .fp-cr-wrap {
                            --fp-cr-border-color: #00a9eb;
                            --fp-cr-surface-soft: #f3f5f7;
                            --fp-cr-page-fill: #eef0f2;
                            color: #111;
                            font-size: 11px;
                            -webkit-print-color-adjust: exact;
                            print-color-adjust: exact;
                        }
                        .fp-cr-wrap .text-end { text-align: right !important; }
                        .fp-cr-wrap * {
                            box-shadow: none !important;
                            outline: none !important;
                        }
                        .fp-cr-top-bar { height: 14px; margin-bottom: 4px; background: linear-gradient(90deg, #10b7a5 0%, #1160aa 82%); }
                        .fp-cr-row {
                            width: 100%;
                            margin-bottom: 3px;
                            border: 0 !important;
                            border-collapse: separate !important;
                            border-spacing: 0 !important;
                        }
                        .fp-cr-row tr, .fp-cr-row td { vertical-align: top; border: 0 !important; }
                        .fp-cr-head-title { background: #0d4f9b; color: #fff; padding: 5px 8px; font-weight: 700; font-size: 12px; text-transform: uppercase; }
                        .fp-cr-head-meta {
                            width: 100%;
                            border: 1px solid var(--fp-cr-border-color);
                            border-top: 0;
                            border-collapse: collapse !important;
                            border-spacing: 0 !important;
                            background-color: var(--fp-cr-page-fill);
                        }
                        .fp-cr-head-meta td {
                            padding: 1px 8px;
                            border: 0 !important;
                            background: var(--fp-cr-page-fill);
                            background-color: var(--fp-cr-page-fill);
                        }
                        .fp-cr-box { border: 2px solid #00a9eb !important; margin-top: 3px; }
                        .fp-cr-box-title { background: #0d4f9b; color: #fff; padding: 4px 8px; font-weight: 700; text-transform: uppercase; }
                        .fp-cr-box-body { padding: 3px 6px; background-color: var(--fp-cr-page-fill); border: 0; }
                        .fp-cr-label { font-weight: 700; }
                        .fp-cr-table {
                            width: 100%;
                            font-size: 10px;
                            border: 0;
                            border-collapse: separate !important;
                            border-spacing: 0 !important;
                        }
                        .fp-cr-table tr { border: 0 !important; }
                        .fp-cr-table th,
                        .fp-cr-table td {
                            border: 0;
                            border-right: 2px solid #00a9eb !important;
                            border-bottom: 2px solid #00a9eb !important;
                            padding: 2px 3px;
                            background-clip: padding-box;
                        }
                        .fp-cr-table tr:first-child > th,
                        .fp-cr-table tr:first-child > td { border-top: 2px solid var(--fp-cr-border-color); }
                        .fp-cr-table th:first-child,
                        .fp-cr-table td:first-child { border-left: 2px solid var(--fp-cr-border-color); }
                        .fp-cr-table th { background: #0d4f9b; color: #fff; text-align: center; }
                        .fp-cr-table td { background-color: #fff; }
                        .fp-cr-table td.text-end { text-align: right; }
                        .fp-cr-grid-2 {
                            width: 100%;
                            margin-top: 4px;
                            border: 0;
                            border-collapse: separate !important;
                            border-spacing: 0 !important;
                        }
                        .fp-cr-grid-2 tr,
                        .fp-cr-grid-2 td { border: 0 !important; }
                        .fp-cr-grid-2 > tbody > tr > td { width: 50%; vertical-align: top; }
                        .fp-cr-small-table {
                            width: 100%;
                            font-size: 12px;
                            border: 0;
                            border-collapse: separate !important;
                            border-spacing: 0 !important;
                        }
                        .fp-cr-small-table tr { border: 0 !important; }
                        .fp-cr-small-table th,
                        .fp-cr-small-table td {
                            border: 0;
                            border-right: 2px solid #00a9eb !important;
                            border-bottom: 2px solid #00a9eb !important;
                            padding: 2px 4px;
                            background-clip: padding-box;
                        }
                        .fp-cr-small-table tr:first-child > th,
                        .fp-cr-small-table tr:first-child > td { border-top: 2px solid #00a9eb !important; }
                        .fp-cr-small-table th:first-child,
                        .fp-cr-small-table td:first-child { border-left: 2px solid #00a9eb !important; }
                        .fp-cr-small-table th { background: #0d4f9b; color: #fff; }
                        .fp-cr-small-table td { background-color: var(--fp-cr-page-fill); }
                        .fp-cr-total td { font-size: 13px; }
                        .fp-cr-receiver-table {
                            width: 100%;
                            table-layout: fixed;
                            border: 0;
                            border-collapse: separate !important;
                            border-spacing: 0 !important;
                        }
                        .fp-cr-receiver-table tr,
                        .fp-cr-receiver-table td {
                            width: 50%;
                            vertical-align: top;
                            padding: 0;
                            border: 0 !important;
                        }
                        .fp-cr-sign { border: 2px solid var(--fp-cr-border-color); margin-top: 4px; padding: 4px 8px; min-height: 40px; }
                        .fp-cr-footer { margin-top: 5px; background: #0d4f9b; color: #fff; padding: 4px 8px; font-size: 10px; }
                        .fp-cr-qr img { max-width: 140px; max-height: 140px; }
                    </style>

                    <div class="fp-cr-wrap">
                        <div class="fp-cr-top-bar"/>

                        <table class="fp-cr-row">
                            <tr>
                                <td style="width:44%; padding-right: 8px;">
                                    <div t-if="o.company_id.logo" style="margin-bottom:6px;">
                                        <img t-att-src="image_data_uri(o.company_id.logo)" style="max-width: 290px; max-height: 95px;"/>
                                    </div>
                                    <div><strong>Datos del emisor: <span t-esc="(o.company_id.name or '').upper()"/></strong></div>
                                    <div><span class="fp-cr-label">Identificación:</span> <span t-esc="o.company_id.vat or ''"/></div>
                                    <div><span class="fp-cr-label">Teléfono:</span> <span t-esc="o.company_id.phone or ''"/></div>
                                    <div><span class="fp-cr-label">Correo electrónico:</span> <span t-esc="o.company_id.email or ''"/></div>
                                    <div><span class="fp-cr-label">Dirección emisor:</span> <span t-esc="', '.join(filter(None, [fp_company_partner.street, fp_company_partner.fp_district_id.name if fp_company_partner.fp_district_id else False, fp_company_partner.fp_canton_id.name if fp_company_partner.fp_canton_id else False, fp_company_partner.fp_province_id.name if fp_company_partner.fp_province_id else False]))"/></div>
                                </td>
                                <td style="width:56%;">
                                    <div class="fp-cr-head-title">
                                        <span t-esc="fp_document_types.get(o.fp_document_type, 'Factura Electrónica')"/>:
                                        <span t-field="o.fp_consecutive_number"/>
                                    </div>
                                    <table class="fp-cr-head-meta" t-att-style="fp_pdf_fill_style">
                                        <tbody>
                                            <tr><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Clave Comprobante:</span> <span t-field="o.fp_external_id"/></td></tr>
                                            <tr><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Fecha de Emisión:</span> <span t-field="o.invoice_date"/></td></tr>
                                            <tr><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Fecha de Vencimiento:</span> <span t-field="o.invoice_date_due"/></td></tr>
                                            <tr t-if="o.delivery_date"><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Fecha de Entrega:</span> <span t-field="o.delivery_date"/></td></tr>
                                            <tr t-if="o.invoice_origin"><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Source / Orden:</span> <span t-esc="o.invoice_origin"/></td></tr>
                                            <tr t-if="o.invoice_incoterm_id"><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Incoterm:</span> <span t-esc="o.invoice_incoterm_id.name"/></td></tr>
                                            <tr t-if="o.ref"><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Referencia:</span> <span t-esc="o.ref"/></td></tr>
                                            <tr><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Condición de Venta:</span> <span t-field="o.fp_sale_condition"/></td></tr>
                                            <tr><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Medio de Pago:</span> <span t-field="o.fp_payment_method"/></td></tr>
                                            <tr><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Moneda Aplicable:</span> <span t-field="o.currency_id"/></td></tr>
                                            <tr><td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Tipo Cambio:</span> <span t-esc="'%.6f' % o._fp_get_exchange_rate()"/></td></tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <t t-set="fp_consignee" t-value="o.partner_shipping_id if o.partner_shipping_id and o.partner_shipping_id.id != o.partner_id.id else False"/>
                        <t t-set="fp_consignee_address" t-value="', '.join(filter(None, [fp_consignee.street, fp_consignee.city, fp_consignee.state_id.name if fp_consignee.state_id else False, fp_consignee.country_id.name if fp_consignee.country_id else False])) if fp_consignee else ''"/>

                        <div class="fp-cr-box" style="border: 2px solid #00a9eb !important;">
                            <div class="fp-cr-box-body" t-att-style="fp_pdf_fill_style">
                                <table class="fp-cr-receiver-table">
                                    <tr>
                                        <!-- BUYER -->
                                        <td t-att-style="fp_pdf_fill_style + ' padding-right: 8px;'">
                                            <div><span class="fp-cr-label">Datos del receptor / Buyer:</span> <span t-esc="fp_receiver_partner.name or ''"/></div>
                                            <div><span class="fp-cr-label">Identificación:</span> <span t-esc="fp_receiver_partner.vat or ''"/></div>
                                            <div t-if="o.fp_document_type != 'TE' or fp_receiver_address"><span class="fp-cr-label">Dirección:</span> <span t-esc="fp_receiver_address"/></div>
                                            <div t-if="o.fp_document_type != 'TE' or fp_receiver_partner.email"><span class="fp-cr-label">Correo:</span> <span t-esc="fp_receiver_partner.email or ''"/></div>
                                            <div t-if="o.fp_document_type != 'TE' or fp_receiver_phone"><span class="fp-cr-label">Teléfono:</span> <span t-esc="fp_receiver_phone"/></div>
                                        </td>
                                        <!-- CONSIGNEE (shipping address if different) -->
                                        <td t-if="fp_consignee" t-att-style="fp_pdf_fill_style + ' padding-left: 8px; border-left: 2px solid #00a9eb !important;'">
                                            <div><span class="fp-cr-label">Consignatario / Consignee:</span> <span t-esc="fp_consignee.name or ''"/></div>
                                            <div t-if="fp_consignee_address"><span class="fp-cr-label">Dirección / Address:</span> <span t-esc="fp_consignee_address"/></div>
                                            <div t-if="fp_consignee.email"><span class="fp-cr-label">Correo / Email:</span> <span t-esc="fp_consignee.email or ''"/></div>
                                            <div t-if="fp_consignee.phone"><span class="fp-cr-label">Teléfono / Phone:</span> <span t-esc="fp_consignee.phone or ''"/></div>
                                            <div t-if="fp_consignee.country_id"><span class="fp-cr-label">País / Country:</span> <span t-esc="fp_consignee.country_id.name or ''"/></div>
                                        </td>
                                        <!-- Fallback when no separate consignee -->
                                        <td t-if="not fp_consignee" t-att-style="fp_pdf_fill_style + ' padding-left: 8px;'">
                                            <div><span class="fp-cr-label">País / Country:</span> <span t-esc="fp_receiver_partner.country_id.name if fp_receiver_partner.country_id else ''"/></div>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <table class="fp-cr-table" style="margin-top:4px;">
                            <thead>
                                <tr>
                                    <th style="width:7%;">Cantidad</th>
                                    <th style="width:8%;">Peso neto (kg)</th>
                                    <th style="width:8%;">Peso bruto (kg)</th>
                                    <th style="width:10%;">Artículo</th>
                                    <th style="width:19%;">Descripción</th>
                                    <th style="width:8%;">UM</th>
                                    <th style="width:14%;">Precio Unit.</th>
                                    <th style="width:10%;">Impuesto</th>
                                    <th style="width:10%;">Descuento</th>
                                    <th style="width:6%;">Valor Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="fp_product_lines" t-as="line">
                                    <tr>
                                        <td class="text-end" t-esc="line.quantity"/>
                                        <td class="text-end" t-esc="'%.3f' % (line.fp_net_weight or line.peso_neto or 0.0)"/>
                                        <td class="text-end" t-esc="'%.3f' % (line.fp_gross_weight or line.peso_total or 0.0)"/>
                                        <td t-esc="line.product_id.fp_cabys_code or '-'"/>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-end" t-esc="line.product_uom_id.name if line.product_uom_id else '-'"/>
                                        <td class="text-end"><span t-field="line.price_unit" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                        <td class="text-end">
                                            <span t-esc="line.price_total - line.price_subtotal" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            <span t-if="line.tax_ids"> (<span t-esc="'%.0f' % (line.tax_ids[0].amount or 0.0)"/>%)</span>
                                        </td>
                                        <td class="text-end"><span t-esc="line.discount"/>%</td>
                                        <td class="text-end"><span t-field="line.price_total" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <table class="fp-cr-grid-2">
                            <tr>
                                <td style="padding-right:8px;">
                                    <table class="fp-cr-small-table" style="border-collapse: separate !important; border-spacing: 0 !important;">
                                        <thead>
                                            <tr><th style="width:40%;">Información adicional</th><th>Detalle</th></tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Referencia</span></td>
                                                <td t-att-style="fp_pdf_fill_style"><span t-esc="fp_reference_value"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label"># interno</span></td>
                                                <td t-att-style="fp_pdf_fill_style"><span t-esc="o.name or '-'"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Observación</span></td>
                                                <td t-att-style="fp_pdf_fill_style"><span t-field="o.narration"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Monto en letras</span></td>
                                                <td t-att-style="fp_pdf_fill_style"><span t-field="o.amount_total_words"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <div t-if="fp_tax_rate_breakdown" style="margin-top:8px; font-weight:700;">Subtotal por tarifas</div>
                                    <table class="fp-cr-small-table" style="margin-top:4px; border-collapse: separate !important; border-spacing: 0 !important;" t-if="fp_tax_rate_breakdown">
                                        <thead>
                                            <tr><th style="width:20%;">Tarifa</th><th style="width:40%;" class="text-end">Importe</th><th style="width:40%;" class="text-end">Impuesto</th></tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="fp_tax_rate_breakdown" t-as="tax_group">
                                                <tr>
                                                    <td t-att-style="fp_pdf_fill_style" class="text-end"><span t-esc="tax_group['rate_label']"/></td>
                                                    <td t-att-style="fp_pdf_fill_style" class="text-end"><span t-esc="tax_group['subtotal']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                                    <td t-att-style="fp_pdf_fill_style" class="text-end"><span t-esc="tax_group['tax']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </td>
                                <td style="padding-left:8px;">
                                    <table class="fp-cr-small-table fp-cr-total" style="border-collapse: separate !important; border-spacing: 0 !important;">
                                        <tbody>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Total gravado</span></td>
                                                <td class="text-end" t-att-style="fp_pdf_fill_style"><span t-esc="fp_summary_totals['total_gravado']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Total exento</span></td>
                                                <td class="text-end" t-att-style="fp_pdf_fill_style"><span t-esc="fp_summary_totals['total_exento']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Total exonerado</span></td>
                                                <td class="text-end" t-att-style="fp_pdf_fill_style"><span t-esc="fp_summary_totals['total_exonerado']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Total no sujeto</span></td>
                                                <td class="text-end" t-att-style="fp_pdf_fill_style"><span t-esc="fp_summary_totals['total_no_sujeto']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Total venta</span></td>
                                                <td class="text-end" t-att-style="fp_pdf_fill_style"><span t-esc="fp_summary_totals['total_venta']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Total descuento</span></td>
                                                <td class="text-end" t-att-style="fp_pdf_fill_style"><span t-esc="fp_summary_totals['total_descuentos']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Total venta neta</span></td>
                                                <td class="text-end" t-att-style="fp_pdf_fill_style"><span t-esc="fp_summary_totals['total_venta_neta']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Total IVA</span></td>
                                                <td class="text-end" t-att-style="fp_pdf_fill_style"><span t-esc="fp_summary_totals['total_impuesto']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                            </tr>
                                            <tr t-if="fp_summary_totals.get('total_otros_cargos')">
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Total otros cargos</span></td>
                                                <td class="text-end" t-att-style="fp_pdf_fill_style"><span t-esc="fp_summary_totals['total_otros_cargos']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                            </tr>
                                            <tr>
                                                <td t-att-style="fp_pdf_fill_style"><span class="fp-cr-label">Total comprobante</span></td>
                                                <td class="text-end" t-att-style="fp_pdf_fill_style"><strong><span t-esc="fp_summary_totals['total_comprobante']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></strong></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <div class="fp-cr-sign">
                                        <div><strong>Recibo Conforme:</strong></div>
                                        <div style="margin-top:22px; border-top:1px solid #333;"/>
                                        <div style="margin-top:4px;">
                                            <span>Firma:</span> _____________________ &amp;nbsp;
                                            <span>Cédula:</span> _____________________
                                        </div>
                                    </div>
                                    <div class="fp-cr-qr" t-if="qr_code_url" style="text-align:right; margin-top:8px;">
                                        <img t-att-src="qr_code_url"/>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <div class="fp-cr-footer">
                            Emitida conforme la resolución de Facturación Electrónica de Costa Rica. Versión del documento 4.4.
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <t t-set="fp_palette" t-value="{
                        'modern_blue': {'primary': '#1d4ed8', 'primary_dark': '#1e3a8a', 'primary_soft': '#eff6ff', 'surface': '#f8fbff', 'text': '#0f172a'},
                        'modern_dark': {'primary': '#334155', 'primary_dark': '#0f172a', 'primary_soft': '#e2e8f0', 'surface': '#f8fafc', 'text': '#0f172a'},
                        'modern_clean': {'primary': '#0f766e', 'primary_dark': '#115e59', 'primary_soft': '#f0fdfa', 'surface': '#f8fafc', 'text': '#0f172a'},
                        'modern_emerald': {'primary': '#059669', 'primary_dark': '#065f46', 'primary_soft': '#ecfdf5', 'surface': '#f7fef9', 'text': '#022c22'},
                        'modern_sunset': {'primary': '#ea580c', 'primary_dark': '#9a3412', 'primary_soft': '#fff7ed', 'surface': '#fffaf5', 'text': '#431407'}
                    }"/>
                    <t t-set="fp_style_key" t-value="fp_template_style if fp_template_style in fp_palette else 'modern_blue'"/>
                    <t t-set="fp_colors" t-value="fp_palette[fp_style_key]"/>

                    <style>
                        .fp-ref-wrap { color: #111827; font-size: 12px; }
                        .fp-ref-wrap .text-end { text-align: right !important; }
                        .fp-ref-banner {
                            border-radius: 16px;
                            color: #0f172a;
                            margin-bottom: 10px;
                            overflow: hidden;
                            border: 1px solid #cbd5e1;
                        }
                        .fp-ref-banner td { vertical-align: top; padding: 0; }
                        .fp-ref-head-box { border-right: 1px solid #cbd5e1; }
                        .fp-ref-head-box:last-child { border-right: 0; }
                        .fp-ref-head-title { color: #fff; font-size: 13px; font-weight: 700; text-transform: uppercase; padding: 8px 10px; }
                        .fp-ref-head-body { background: #fff; padding: 10px 12px; }
                        .fp-ref-company { font-size: 22px; font-weight: 700; line-height: 1.2; margin-bottom: 8px; }
                        .fp-ref-line { margin-bottom: 3px; font-size: 12px; }
                        .fp-ref-line--break { word-break: break-all; }
                        .fp-ref-line strong { font-weight: 700; }
                        .fp-ref-card {
                            border: 0;
                            border-radius: 0;
                            margin-bottom: 8px;
                            overflow: visible;
                            background: transparent;
                        }
                        .fp-ref-card-title {
                            color: #ffffff;
                            font-size: 12px;
                            font-weight: 700;
                            text-transform: uppercase;
                            letter-spacing: 0.4px;
                            padding: 8px 10px;
                        }
                        .fp-ref-card-body { padding: 8px 2px 6px 2px; }
                        .fp-ref-grid { width: 100%; border-collapse: collapse; table-layout: fixed; }
                        .fp-ref-grid td { width: 50%; vertical-align: top; padding: 0 8px 0 0; }
                        .fp-ref-grid td:last-child { padding-right: 0; }
                        .fp-ref-data-row { margin-bottom: 5px; }
                        .fp-ref-label { font-weight: 700; color: #1e293b; margin-right: 5px; }
                        .fp-ref-table { width: 100%; border-collapse: collapse; font-size: 11.5px; }
                        .fp-ref-table th, .fp-ref-table td { border: 1px solid #cbd5e1; padding: 5px 6px; }
                        .fp-ref-table th { color: #fff; font-size: 11px; text-transform: uppercase; }
                        .fp-ref-table td.text-end { text-align: right; }
                        .fp-ref-summary { width: 46%; margin-left: auto; margin-top: 10px; }
                        .fp-ref-summary td { border-bottom: 1px solid #e2e8f0; padding: 4px 0; }
                        .fp-ref-summary tr:last-child td { border-bottom: 0; }
                        .fp-ref-summary .fp-ref-grand td { font-size: 14px; font-weight: 700; border-top: 2px solid #94a3b8; padding-top: 6px; }
                        .fp-ref-note {
                            margin-top: 10px;
                            border: 1px solid #cbd5e1;
                            border-radius: 10px;
                            padding: 8px 10px;
                            font-size: 11px;
                            color: #334155;
                            background: #f8fafc;
                        }
                        .fp-ref-qr img { max-width: 110px; max-height: 110px; }
                    </style>

                    <div class="fp-ref-wrap">
                        <table class="fp-ref-banner" style="width:100%; background:#ffffff;">
                            <tr>
                                <td class="fp-ref-head-box" style="width:54%;">
                                    <div class="fp-ref-head-title" t-attf-style="background: #{fp_colors['primary_dark']};">Datos del emisor</div>
                                    <div class="fp-ref-head-body" t-attf-style="background: #{fp_colors['surface']};">
                                        <div class="fp-ref-company" t-esc="o.company_id.name or ''"/>
                                        <div class="fp-ref-line"><strong>Identificación:</strong> <span t-esc="o.company_id.vat or '-'"/></div>
                                        <div class="fp-ref-line"><strong>Correo:</strong> <span t-esc="o.company_id.email or '-'"/></div>
                                        <div class="fp-ref-line"><strong>Teléfono:</strong> <span t-esc="o.company_id.phone or '-'"/></div>
                                        <div class="fp-ref-line"><strong>Dirección:</strong> <span t-esc="', '.join(filter(None, [fp_company_partner.street, fp_company_partner.fp_district_id.name if fp_company_partner.fp_district_id else False, fp_company_partner.fp_canton_id.name if fp_company_partner.fp_canton_id else False, fp_company_partner.fp_province_id.name if fp_company_partner.fp_province_id else False])) or '-'"/></div>
                                    </div>
                                </td>
                                <td class="fp-ref-head-box" style="width:46%;">
                                    <div class="fp-ref-head-title" t-attf-style="background: #{fp_colors['primary_dark']};">Resumen del documento</div>
                                    <div class="fp-ref-head-body" t-attf-style="background: #{fp_colors['surface']};">
                                        <div class="fp-ref-line"><strong>Tipo:</strong>&#160;<span t-esc="fp_document_types.get(o.fp_document_type, o.fp_document_type or o.move_type)"/></div>
                                        <div class="fp-ref-line fp-ref-line--break"><strong>Clave comprobante:</strong>&#160;<span t-esc="fp_electronic_key_value or '-'"/></div>
                                        <div class="fp-ref-line"><strong>Consecutivo:</strong>&#160;<span t-esc="fp_consecutive_value or '-'"/></div>
                                        <div class="fp-ref-line"><strong>Fecha de emisión:</strong>&#160;<span t-field="o.invoice_date"/></div>
                                        <div class="fp-ref-line"><strong>Fecha de vencimiento:</strong>&#160;<span t-field="o.invoice_date_due"/></div>
                                        <div class="fp-ref-line"><strong>Condición de venta:</strong>&#160;<span t-esc="fp_sale_condition_label or '-'"/></div>
                                        <div class="fp-ref-line"><strong>Medio de pago:</strong>&#160;<span t-esc="fp_payment_method_label or '-'"/></div>
                                        <div class="fp-ref-line"><strong>Moneda:</strong>&#160;<span t-esc="o.currency_id.name"/></div>
                                        <div class="fp-ref-line"><strong>Tipo de cambio:</strong>&#160;<span t-esc="fp_currency_rate_value"/></div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <table class="fp-ref-grid">
                            <tr>
                                <td style="width:100%; padding-right:0;">
                                    <div class="fp-ref-card" t-attf-style="background: #{fp_colors['surface']};">
                                        <div class="fp-ref-card-title" t-attf-style="background: #{fp_colors['primary_dark']};">Receptor</div>
                                        <div class="fp-ref-card-body">
                                            <div class="fp-ref-data-row"><span class="fp-ref-label">Nombre:</span>&#160;<span t-esc="fp_receiver_partner.name or ''"/></div>
                                            <div class="fp-ref-data-row"><span class="fp-ref-label">Identificación:</span>&#160;<span t-esc="fp_receiver_partner.vat or '-'"/></div>
                                            <div class="fp-ref-data-row"><span class="fp-ref-label">Correo:</span>&#160;<span t-esc="fp_receiver_partner.email or '-'"/></div>
                                            <div class="fp-ref-data-row" t-if="o.fp_document_type != 'TE' or fp_receiver_phone"><span class="fp-ref-label">Teléfono:</span>&#160;<span t-esc="fp_receiver_phone or '-'"/></div>
                                            <div class="fp-ref-data-row"><span class="fp-ref-label">Dirección:</span>&#160;<span t-esc="fp_receiver_address or '-'"/></div>
                                            <div class="fp-ref-qr" t-if="qr_code_url" style="text-align:right; margin-top:6px;"><img t-att-src="qr_code_url"/></div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <table class="fp-ref-table">
                            <thead>
                                <tr t-attf-style="background: #{fp_colors['primary']};">
                                    <th style="width: 12%;">CABYS</th>
                                    <th style="width: 21%;">Detalle</th>
                                    <th class="text-end" style="width: 10%;">Cantidad</th>
                                    <th class="text-end" style="width: 10%;">Peso neto (kg)</th>
                                    <th class="text-end" style="width: 10%;">Peso bruto (kg)</th>
                                    <th class="text-end" style="width: 11%;">Precio Unit.</th>
                                    <th class="text-end" style="width: 14%;">Impuesto</th>
                                    <th class="text-end" style="width: 12%;">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="fp_product_lines" t-as="line">
                                    <tr>
                                        <td t-esc="line.product_id.fp_cabys_code or '-'"/>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-end" t-esc="line.quantity"/>
                                        <td class="text-end" t-esc="'%.3f' % (line.fp_net_weight or line.peso_neto or 0.0)"/>
                                        <td class="text-end" t-esc="'%.3f' % (line.fp_gross_weight or line.peso_total or 0.0)"/>
                                        <td class="text-end"><span t-field="line.price_unit" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                        <td class="text-end"><span t-esc="line.price_total - line.price_subtotal" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                        <td class="text-end"><span t-field="line.price_subtotal" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <table class="fp-ref-summary">
                            <tr><td><span class="fp-ref-label">Total gravado</span></td><td class="text-end"><span t-esc="fp_summary_totals['total_gravado']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td></tr>
                            <tr><td><span class="fp-ref-label">Total exento</span></td><td class="text-end"><span t-esc="fp_summary_totals['total_exento']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td></tr>
                            <tr><td><span class="fp-ref-label">Total exonerado</span></td><td class="text-end"><span t-esc="fp_summary_totals['total_exonerado']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td></tr>
                            <tr><td><span class="fp-ref-label">Total no sujeto</span></td><td class="text-end"><span t-esc="fp_summary_totals['total_no_sujeto']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td></tr>
                            <tr><td><span class="fp-ref-label">Total venta neta</span></td><td class="text-end"><span t-esc="fp_summary_totals['total_venta_neta']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td></tr>
                            <tr><td><span class="fp-ref-label">Total IVA</span></td><td class="text-end"><span t-esc="fp_summary_totals['total_impuesto']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td></tr>
                            <tr t-if="fp_summary_totals.get('total_otros_cargos')"><td><span class="fp-ref-label">Total otros cargos</span></td><td class="text-end"><span t-esc="fp_summary_totals['total_otros_cargos']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td></tr>
                            <tr class="fp-ref-grand"><td><span>Total comprobante</span></td><td class="text-end"><span t-esc="fp_summary_totals['total_comprobante']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td></tr>
                        </table>

                        <div class="fp-ref-note" t-attf-style="border-left: 4px solid #{fp_colors['primary']};">
                            Emitida conforme la resolución de Facturación Electrónica de Costa Rica (v4.4).
                        </div>
                    </div>
                </t>
            </div>
        </t>
    </template>
</odoo>
