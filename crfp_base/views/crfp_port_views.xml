<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crfp_port_tree" model="ir.ui.view">
        <field name="name">crfp.port.tree</field>
        <field name="model">crfp.port</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="country"/>
                <field name="region"/>
            </list>
        </field>
    </record>

    <record id="crfp_port_form" model="ir.ui.view">
        <field name="name">crfp.port.form</field>
        <field name="model">crfp.port</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="country"/>
                            <field name="region"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes about this port..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_crfp_port" model="ir.actions.act_window">
        <field name="name">Ports</field>
        <field name="res_model">crfp.port</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
