<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crfp_incoterm_matrix_tree" model="ir.ui.view">
        <field name="name">crfp.incoterm.matrix.tree</field>
        <field name="model">crfp.incoterm.matrix</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="inc_transport"/>
                <field name="inc_fumigation"/>
                <field name="inc_thc_origin"/>
                <field name="inc_broker"/>
                <field name="inc_freight"/>
                <field name="inc_insurance"/>
                <field name="inc_thc_dest"/>
                <field name="inc_fumig_dest"/>
                <field name="inc_inland_dest"/>
                <field name="inc_duties"/>
            </list>
        </field>
    </record>

    <record id="action_crfp_incoterm_matrix" model="ir.actions.act_window">
        <field name="name">Incoterm Matrix</field>
        <field name="res_model">crfp.incoterm.matrix</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
