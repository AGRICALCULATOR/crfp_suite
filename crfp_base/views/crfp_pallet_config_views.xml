<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crfp_pallet_config_tree" model="ir.ui.view">
        <field name="name">crfp.pallet.config.tree</field>
        <field name="model">crfp.pallet.config</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_keyword"/>
                <field name="weight_kg"/>
                <field name="boxes_per_pallet"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <record id="action_crfp_pallet_config" model="ir.actions.act_window">
        <field name="name">Pallet Configuration</field>
        <field name="res_model">crfp.pallet.config</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
