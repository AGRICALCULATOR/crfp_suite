<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crfp_container_type_tree" model="ir.ui.view">
        <field name="name">crfp.container.type.tree</field>
        <field name="model">crfp.container.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="capacity_boxes"/>
                <field name="is_reefer"/>
            </list>
        </field>
    </record>

    <record id="crfp_container_type_form" model="ir.ui.view">
        <field name="name">crfp.container.type.form</field>
        <field name="model">crfp.container.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="capacity_boxes"/>
                            <field name="is_reefer"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_crfp_container_type" model="ir.actions.act_window">
        <field name="name">Container Types</field>
        <field name="res_model">crfp.container.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
