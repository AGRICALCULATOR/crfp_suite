<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crfp_settings_form" model="ir.ui.view">
        <field name="name">crfp.settings.form</field>
        <field name="model">crfp.settings</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h2><field name="name"/></h2>

                    <!-- Exchange Rate — Centralizado con Odoo Contabilidad -->
                    <group string="Tipo de Cambio">
                        <group>
                            <field name="exchange_rate_source"/>
                            <field name="exchange_rate"/>
                            <field name="exchange_rate_last_update" readonly="1"/>
                        </group>
                        <group>
                            <div>
                                <button name="action_update_exchange_rate"
                                        string="Sincronizar Tipo de Cambio"
                                        type="object"
                                        class="btn-primary"/>
                                <p class="text-muted mt-2" style="font-size:0.85em;">
                                    Lee la tasa USD/CRC de Contabilidad (res.currency.rate).
                                    La misma fuente que usa la Factura Electrónica.
                                    Configure el proveedor en:
                                    Contabilidad → Configuración → Monedas → Tasas automáticas.
                                </p>
                            </div>
                        </group>
                    </group>

                    <!-- Container &amp; Box Defaults -->
                    <group string="Container &amp; Box Defaults">
                        <group>
                            <field name="default_total_boxes"/>
                            <field name="default_boxes_per_pallet"/>
                        </group>
                    </group>

                    <!-- Default Fixed Costs (loaded into new quotations) -->
                    <group string="Default Fixed Costs (loaded into new quotations)">
                        <group string="Origin">
                            <field name="fc_transport_default"/>
                            <field name="fc_thc_origin_default"/>
                            <field name="fc_fumigation_default"/>
                            <field name="fc_broker_default"/>
                        </group>
                        <group string="Destination">
                            <field name="fc_thc_dest_default"/>
                            <field name="fc_fumig_dest_default"/>
                            <field name="fc_inland_dest_default"/>
                            <field name="fc_insurance_pct_default"/>
                            <field name="fc_duties_pct_default"/>
                        </group>
                    </group>

                    <!-- Quality &amp; Monitoring -->
                    <group string="Quality &amp; Monitoring">
                        <group>
                            <field name="temperature_tolerance"/>
                            <field name="price_validity_days"/>
                        </group>
                    </group>

                    <group groups="base.group_multi_company">
                        <field name="company_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Keep original act_window (already in DB) -->
    <record id="action_crfp_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">crfp.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <!-- Server action that opens the singleton record directly -->
    <record id="action_open_crfp_settings" model="ir.actions.server">
        <field name="name">Settings</field>
        <field name="model_id" ref="crfp_base.model_crfp_settings"/>
        <field name="state">code</field>
        <field name="code">
record = env['crfp.settings'].get_settings()
action = {
    'type': 'ir.actions.act_window',
    'name': 'CR Farm Settings',
    'res_model': 'crfp.settings',
    'res_id': record.id,
    'view_mode': 'form',
    'target': 'current',
}
        </field>
    </record>
</odoo>
