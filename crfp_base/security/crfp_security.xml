<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_crfp" model="ir.module.category">
        <field name="name">CR Farm Export Suite</field>
        <field name="description">CR Farm Products export management suite</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_crfp_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_crfp"/>
    </record>

    <record id="group_crfp_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_crfp"/>
        <field name="implied_ids" eval="[(4, ref('group_crfp_user'))]"/>
    </record>
</odoo>
