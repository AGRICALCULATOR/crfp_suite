<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_inherit_weight" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.weight</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom_qty']"
                   position="after">
                <field name="peso_neto" optional="show"/>
                <field name="peso_total" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
