<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_form_inherit_weight" model="ir.ui.view">
        <field name="name">account.move.form.inherit.weight</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='quantity'][ancestor::field[@name='invoice_line_ids']]"
                   position="after">
                <field name="peso_neto" optional="show"/>
                <field name="peso_total" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
